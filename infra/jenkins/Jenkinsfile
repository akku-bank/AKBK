pipeline {
    agent any
    environment {
        MM_WEBHOOK = credentials('mattermost-webhook-url')
    }
    stages {
        stage('Infrastructure Check') {
            steps {
                script {
                    sh '[ -f infra/docker-compose.yml ] && docker-compose -f infra/docker-compose.yml config || echo "Skip check"'
                }
            }
        }
        stage('Build Services') {
            steps {
                script {
                    try {
                        sh 'echo "[TEST] java.lang.NullPointerException 발생!!" && exit 1'
                    } catch (Exception e) {
                        currentBuild.result = 'FAILURE'
                        error "❌ 빌드 단계에서 에러 발생"
                    }
                }
            }
        }
    }
    post {
        failure {
            script {
                // 1. 로그 추출 및 파이썬 분석 (이전과 동일)
                def logFile = "${env.WORKSPACE}/extracted_log.txt"
                sh "tail -n 50 /var/jenkins_home/jobs/${env.JOB_NAME}/builds/${env.BUILD_NUMBER}/log > ${logFile}"
                
                def resultFile = "${env.WORKSPACE}/analysis_result.json"
                // 파이썬이 JSON 파일 자체를 생성하도록 변경 (출력 가공 에러 방지)
                sh "python3 infra/jenkins/analyze_log.py ${logFile} > ${resultFile}"

                // 2. Mattermost 전송용 최종 JSON 파일 생성 (쉘에서 가공하여 깨짐 방지)
                // Groovy 변수를 거치지 않고 직접 파일을 생성해 Serialization 에러를 회피합니다.
                sh """
                TEAM=\$(cat ${resultFile} | python3 -c "import sys, json; print(json.load(sys.stdin)['team'])")
                SUMMARY=\$(cat ${resultFile} | python3 -c "import sys, json; print(json.load(sys.stdin)['summary'])")
                
                cat <<EOF > final_payload.json
                {
                    "username": "Jenkins-Analyzer",
                    "icon_url": "https://jenkins.io/images/logos/jenkins/jenkins.png",
                    "text": "### 🚨 [\$TEAM] 빌드 실패 알림\\n**프로젝트:** ${env.JOB_NAME}\\n**빌드 번호:** #${env.BUILD_NUMBER}\\n**에러 분석:**\\n\`\`\`\\n\$SUMMARY\\n\`\`\`\\n\\n[👉 상세 로그 확인하기](${env.BUILD_URL}console)"
                }
EOF
                """

                // 3. Webhook 전송 (파일을 직접 전송하여 특수문자 문제 완전 해결)
                sh "curl -sS -X POST -H 'Content-Type: application/json' -d @final_payload.json ${MM_WEBHOOK}"
            }
        }
    }
}