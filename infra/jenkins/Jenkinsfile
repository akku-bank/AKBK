pipeline {
    agent any
    environment {
        MM_WEBHOOK = credentials('mattermost-webhook-url')
    }
    stages {
        stage('Infrastructure Check') {
            steps {
                script {
                    sh '[ -f infra/docker-compose.yml ] && docker-compose -f infra/docker-compose.yml config || echo "Skip check"'
                }
            }
        }
        stage('Build Services') {
            steps {
                script {
                    try {
                        sh 'echo "[TEST] java.lang.NullPointerException 발생!!" && exit 1'
                    } catch (Exception e) {
                        currentBuild.result = 'FAILURE'
                        error "❌ 빌드 단계에서 에러 발생"
                    }
                }
            }
        }
    }
    post {
        failure {
            script {
                // 1. 로그 추출 (이전과 동일)
                def logFile = "${env.WORKSPACE}/extracted_log.txt"
                sh "tail -n 50 /var/jenkins_home/jobs/${env.JOB_NAME}/builds/${env.BUILD_NUMBER}/log > ${logFile}"
                
                // 2. 파이썬 실행 (이 부분이 핵심입니다!)
                // 파이썬에게 '로그파일', '결과파일경로', '잡이름', '빌드주소'를 모두 넘겨줍니다.
                // 파이썬 안에서 Mattermost용 JSON을 직접 완성하게 만듭니다.
                sh "python3 infra/jenkins/analyze_log.py ${logFile} ${env.JOB_NAME} ${env.BUILD_NUMBER} ${env.BUILD_URL}"

                // 3. 생성된 JSON 파일을 그대로 전송
                // 파이썬이 'mattermost_payload.json'이라는 파일을 만들도록 할 것입니다.
                sh "curl -sS -X POST -H 'Content-Type: application/json' -d @mattermost_payload.json ${MM_WEBHOOK}"
            }
        }
    }
}