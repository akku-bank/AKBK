pipeline {
    agent any

    environment {
        // Credentials ID가 'mattermost-webhook-url'인지 꼭 확인하세요!
        MM_WEBHOOK = credentials('mattermost-webhook-url')
    }

    stages {
        stage('Infrastructure Check') {
            steps {
                script {
                    sh '''
                        if [ -f "infra/docker-compose.yml" ]; then
                            docker-compose -f infra/docker-compose.yml config
                        elif [ -f "docker-compose.yml" ]; then
                            docker-compose config
                        else
                            echo "docker-compose.yml 파일을 찾을 수 없습니다."
                        fi
                    '''
                }
            }
        }
        stage('Build Services') {
            steps {
                script {
                    try {
                        // 에러 분석 테스트를 위한 강제 실패
                        sh 'echo "NullPointerException 발생 테스트!!" && exit 1'
                    } catch (Exception e) {
                        currentBuild.result = 'FAILURE'
                        error "Build Failed"
                    }
                }
            }
        }
    }

    post {
        failure {
            script {
                // 1. 보안 승인이 필요 없는 직접 파일 접근 방식 (물리 경로 사용)
                def logFile = "extracted_log.txt"
                sh "tail -n 100 /var/jenkins_home/jobs/${env.JOB_NAME}/builds/${env.BUILD_NUMBER}/log > ${logFile} || echo 'Log capture failed' > ${logFile}"

                // 2. 파이썬 분석 실행 (경로 확인 필수!)
                // analyze_log.py가 infra/jenkins 폴더 안에 있는지 확인하세요.
                def resultJson = sh(script: "python3 infra/jenkins/analyze_log.py ${logFile}", returnStdout: true).trim()
                def result = new groovy.json.JsonSlurper().parseText(resultJson)

                // 3. Mattermost 전송 페이로드 구성
                def payload = """
                {
                    "text": "### 🚨 [${result.team}] 빌드 실패 발생\\n**Job:** ${env.JOB_NAME}\\n**에러 요약:**\\n```\\n${result.summary}\\n```\\n[로그 보기](${env.BUILD_URL}console)"
                }
                """
                // Webhook 전송
                sh "curl -sS -X POST -H 'Content-Type: application/json' -d '${payload}' ${MM_WEBHOOK}"
            }
        }
    }
}